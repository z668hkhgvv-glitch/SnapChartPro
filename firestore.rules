rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // userTeams/{uid} — only the owner can read/write their own lookup doc
    match /userTeams/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything under teams/{teamId} requires a signed-in user.
    // Role enforcement (admin / editor / readonly) is handled in app code.
    match /teams/{teamId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Invites — any signed-in user can read/write (key is obscured by emailKey encoding)
    match /invites/{emailKey} {
      allow read, write: if request.auth != null;
    }
  }
}
